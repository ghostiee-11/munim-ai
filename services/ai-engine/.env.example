# MunimAI Backend Environment Variables

# Groq API (Free tier: https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=mixtral-8x7b-32768
GROQ_WHISPER_MODEL=whisper-large-v3

# Supabase (Free tier: https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Redis (Free tier: https://upstash.com)
REDIS_URL=redis://default:your-password@your-host.upstash.io:6379

# Sarvam AI TTS (https://sarvam.ai)
SARVAM_API_KEY=your-sarvam-key-here

# WhatsApp Business API (Meta Cloud)
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=munim-ai-verify

# App Config
ENVIRONMENT=development
DEBUG=true
